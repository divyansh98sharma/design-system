{
  "name": "ds-workspace",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "storybook": "ng run ds-workspace:storybook",
    "build-storybook": "ng run ds-workspace:build-storybook",
    "test-storybook": "test-storybook",
    "chromatic": "chromatic --exit-zero-on-changes",
    "tokens:build": "style-dictionary build --config ./style-dictionary.config.mjs",
    "tokens:watch": "style-dictionary build --config ./style-dictionary.config.mjs --watch",
    "tokens:clean": "style-dictionary clean --config ./style-dictionary.config.mjs"
  },
  "private": true,
  "packageManager": "npm@11.11.0",
  "dependencies": {
    "@angular/animations": "^21.2.13",
    "@angular/cdk": "^21.2.10",
    "@angular/common": "^21.2.13",
    "@angular/compiler": "^21.2.12",
    "@angular/core": "^21.2.13",
    "@angular/forms": "^21.2.13",
    "@angular/platform-browser": "^21.2.13",
    "@angular/router": "^21.2.13",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-devkit/architect": "^0.2102.0",
    "@angular-devkit/build-angular": "^21.2.11",
    "@angular-devkit/core": "^21.2.10",
    "@angular/build": "^21.2.12",
    "@angular/cli": "^21.2.10",
    "@angular/compiler-cli": "^21.2.13",
    "@angular/platform-browser-dynamic": "^21.2.13",
    "@compodoc/compodoc": "^1.2.1",
    "@storybook/addon-a11y": "^10.4.0",
    "@storybook/addon-docs": "^10.4.0",
    "@storybook/addon-onboarding": "^10.4.0",
    "@storybook/angular": "^10.4.0",
    "@storybook/test-runner": "^0.24.4",
    "chromatic": "^16.10.1",
    "http-server": "^14.1.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "storybook": "^10.4.0",
    "style-dictionary": "^5.4.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.6",
    "wait-on": "^9.0.10"
  },
  "overrides": {
    "uuid": "^14.0.0",
    "picomatch": "^4.0.4",
    "ajv": "^8.20.0"
  }
}
